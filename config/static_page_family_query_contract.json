{
  "schema_version": "static-page-family-query-contract.v1",
  "contract_doc": "docs/project/STATIC_PAGE_FAMILY_QUERY_CONTRACT.md",
  "page_families": [
    {
      "page_family": "home",
      "query_contract_id": "page-query.home.v1",
      "description": "Top-level landing page built from reviewed/current overview counts and curated recent updates.",
      "inputs": [
        {
          "input_name": "home_overview_query",
          "kind": "query",
          "upstream_contract_ref": "local-search-projection.v1",
          "required": true,
          "purpose": "Produces reviewed/current counts, top facets, and recent public-safe highlights."
        },
        {
          "input_name": "home_blocker_sidecar",
          "kind": "sidecar",
          "upstream_contract_ref": "correction-ledger.v1",
          "required": false,
          "purpose": "Explains corrected or superseded IDs without surfacing private lineage details as primary page content."
        }
      ],
      "sparse_state": {
        "reader_state": "sparse",
        "trigger_signals": [
          "overview counts available but recent highlights missing",
          "public-safe lineage note available without facet rollups"
        ],
        "retained_sections": [
          "headline summary",
          "navigation",
          "public-safe recent updates"
        ]
      },
      "field_visibility": {
        "public_fields": [
          "headline",
          "summary_cards",
          "top_facets",
          "recent_entities",
          "lineage_summary"
        ],
        "private_fields": [
          "private_path",
          "operator_note",
          "raw_payload_excerpt",
          "restricted_evidence_text"
        ],
        "conditional_public_fields": [
          "evidence_summary",
          "public_blocker_summary"
        ]
      },
      "empty_example": {
        "reader_state": "empty",
        "query_status": "no reviewed/current public-safe rows",
        "visible_sections": [
          "empty_state_message",
          "navigation"
        ],
        "hidden_sections": [
          "summary_cards",
          "recent_entities"
        ]
      },
      "populated_example": {
        "reader_state": "ready",
        "query_status": "reviewed/current overview rows available",
        "visible_sections": [
          "summary_cards",
          "top_facets",
          "recent_entities",
          "lineage_summary"
        ],
        "hidden_sections": []
      }
    },
    {
      "page_family": "facet",
      "query_contract_id": "page-query.facet.v1",
      "description": "Facet rollup page showing reviewed/current members, related facets, and sparse public-safe context.",
      "inputs": [
        {
          "input_name": "facet_member_query",
          "kind": "query",
          "upstream_contract_ref": "local-search-projection.v1",
          "required": true,
          "purpose": "Returns reviewed/current member rows for one facet with authority and publication posture."
        },
        {
          "input_name": "facet_evidence_summary",
          "kind": "sidecar",
          "upstream_contract_ref": "evidence-locator.v1",
          "required": false,
          "purpose": "Allows public-safe evidence summaries without quoting restricted text."
        }
      ],
      "sparse_state": {
        "reader_state": "sparse",
        "trigger_signals": [
          "facet title resolved but no reviewed member rows",
          "members available but related facet links missing"
        ],
        "retained_sections": [
          "facet heading",
          "member count summary",
          "related facet placeholders"
        ]
      },
      "field_visibility": {
        "public_fields": [
          "facet_title",
          "facet_summary",
          "member_rows",
          "related_facet_routes"
        ],
        "private_fields": [
          "local_workspace_path",
          "operator_triage_note",
          "raw_member_payload"
        ],
        "conditional_public_fields": [
          "evidence_summary",
          "lineage_summary"
        ]
      },
      "empty_example": {
        "reader_state": "empty",
        "query_status": "facet exists but no current public-safe members",
        "visible_sections": [
          "facet_heading",
          "empty_state_message"
        ],
        "hidden_sections": [
          "member_rows"
        ]
      },
      "populated_example": {
        "reader_state": "ready",
        "query_status": "facet members and related routes available",
        "visible_sections": [
          "facet_heading",
          "member_rows",
          "related_facet_routes",
          "evidence_summary"
        ],
        "hidden_sections": []
      }
    },
    {
      "page_family": "entity",
      "query_contract_id": "page-query.entity.v1",
      "description": "Entity detail page built from reviewed/current canonical rows with optional public-safe lineage and evidence summaries.",
      "inputs": [
        {
          "input_name": "entity_detail_query",
          "kind": "query",

        "conditional_public_fields": [
          "lineage_summary",
          "evidence_summary",
          "public_blocker_summary"
        ]
      },
      "empty_example": {
        "reader_state": "empty",
        "query_status": "entity route reserved but no reviewed/current public-safe entity row",
        "visible_sections": [
          "empty_state_message"
        ],
        "hidden_sections": [
          "identity_summary",
          "related_relationships"
        ]
      },
      "populated_example": {
        "reader_state": "ready",
        "query_status": "entity row and related public-safe sections available",
        "visible_sections": [
          "identity_summary",
          "public_summary",
          "related_relationships",
          "evidence_summary"
        ],
        "hidden_sections": []
      }
    },
    {
      "page_family": "source",

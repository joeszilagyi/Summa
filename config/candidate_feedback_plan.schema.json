{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summa.local/schemas/candidate_feedback_plan.schema.json",
  "title": "candidate-feedback-plan.v1",
  "description": "Deterministic subject-scoped next-action selection plan for the gather loop.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "subject",
    "canonical_store",
    "scoring_policy",
    "counts",
    "facet_scores",
    "lead_scores",
    "next_action",
    "deferred",
    "selection_explanation",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "const": "candidate-feedback-plan.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "display_name",
        "domain_pack",
        "enabled_facets",
        "query_families"
      ],
      "properties": {
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "domain_pack": {
          "type": "string",
          "minLength": 1
        },
        "enabled_facets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "query_families": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "canonical_store": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "database_name",
        "schema_version",
        "current_migration_id",
        "dry_run"
      ],
      "properties": {
        "database_name": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "current_migration_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "dry_run": {
          "const": true
        }
      }
    },
    "scoring_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "cycle_depth_considered",
        "previous_run_ids_considered",
        "use_prior_state",
        "weights",
        "limits"
      ],
      "properties": {
        "policy_id": {
          "const": "candidate-feedback.default.v1"
        },
        "cycle_depth_considered": {
          "type": "integer",
          "minimum": 1
        },
        "previous_run_ids_considered": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "use_prior_state": {
          "type": "boolean"
        },
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "productive_run",
            "open_lead",
            "work_yield",
            "claim_yield",
            "entity_yield",
            "relationship_yield",
            "successful_extraction",
            "failed_extraction_penalty",
            "zero_yield_penalty",
            "recent_low_yield_penalty",
            "bootstrap_bias"
          ],
          "properties": {
            "productive_run": { "type": "number" },
            "open_lead": { "type": "number" },
            "work_yield": { "type": "number" },
            "claim_yield": { "type": "number" },
            "entity_yield": { "type": "number" },
            "relationship_yield": { "type": "number" },
            "successful_extraction": { "type": "number" },
            "failed_extraction_penalty": { "type": "number" },
            "zero_yield_penalty": { "type": "number" },
            "recent_low_yield_penalty": { "type": "number" },
            "bootstrap_bias": { "type": "number" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_facet_candidates",
            "max_lead_candidates",
            "max_deferred_candidates"
          ],
          "properties": {
            "max_facet_candidates": {
              "type": "integer",
              "minimum": 1
            },
            "max_lead_candidates": {
              "type": "integer",
              "minimum": 1
            },
            "max_deferred_candidates": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gather_runs_considered",
        "facet_candidates",
        "facet_candidates_total",
        "lead_candidates",
        "lead_candidates_total",
        "productive_leads",
        "productive_leads_total",
        "deferred_candidates"
      ],
      "properties": {
        "gather_runs_considered": {
          "type": "integer",
          "minimum": 0
        },
        "facet_candidates": {
          "type": "integer",
          "minimum": 0
        },
        "facet_candidates_total": {
          "type": "integer",
          "minimum": 0
        },
        "lead_candidates": {
          "type": "integer",
          "minimum": 0
        },
        "lead_candidates_total": {
          "type": "integer",
          "minimum": 0
        },
        "productive_leads": {
          "type": "integer",
          "minimum": 0
        },
        "productive_leads_total": {
          "type": "integer",
          "minimum": 0
        },
        "deferred_candidates": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "facet_scores": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/facet_score"
      }
    },
    "lead_scores": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lead_score"
      }
    },
    "next_action": {
      "$ref": "#/$defs/next_action"
    },
    "deferred": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deferred_candidate"
      }
    },
    "selection_explanation": {
      "$ref": "#/$defs/selection_explanation"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "signal_bucket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productive_runs",
        "zero_yield_runs",
        "open_leads",
        "works",
        "claims",
        "entities",
        "relationships",
        "successful_extractions",
        "failed_extractions"
      ],
      "properties": {
        "productive_runs": { "type": "integer", "minimum": 0 },
        "zero_yield_runs": { "type": "integer", "minimum": 0 },
        "open_leads": { "type": "integer", "minimum": 0 },
        "works": { "type": "integer", "minimum": 0 },
        "claims": { "type": "integer", "minimum": 0 },
        "entities": { "type": "integer", "minimum": 0 },
        "relationships": { "type": "integer", "minimum": 0 },
        "successful_extractions": { "type": "integer", "minimum": 0 },
        "failed_extractions": { "type": "integer", "minimum": 0 }
      }
    },
    "facet_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "candidate_id",
        "facet",
        "prompt_bundle_id",
        "score",
        "selected",
        "supporting_facet",
        "reason_codes",
        "rationale",
        "signals"
      ],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "candidate_id": {
          "type": "string",
          "pattern": "^facet:[a-z0-9_][a-z0-9._-]*$"
        },
        "facet": {
          "type": "string",
          "minLength": 1
        },
        "prompt_bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "minimum": -100.0,
          "maximum": 100.0
        },
        "selected": {
          "type": "boolean"
        },
        "supporting_facet": {
          "type": "boolean"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "signals": {
          "$ref": "#/$defs/signal_bucket"
        }
      }
    },
    "lead_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "candidate_id",
        "lead_kind",
        "object_ref",
        "facet",
        "review_state",
        "label",
        "score",
        "selected",
        "reason_codes",
        "rationale",
        "signals",
        "related_run_ids"
      ],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "lead_kind": {
          "type": "string",
          "enum": [
            "source_access",
            "source_claim",
            "detected_entity",
            "work"
          ]
        },
        "object_ref": {
          "type": "string",
          "minLength": 1
        },
        "facet": {
          "type": "string",
          "minLength": 1
        },
        "review_state": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "minimum": -100.0,
          "maximum": 100.0
        },
        "selected": {
          "type": "boolean"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "signals": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "open_lead",
            "related_works",
            "related_claims",
            "related_entities",
            "successful_extractions",
            "failed_extractions",
            "zero_yield_attempts"
          ],
          "properties": {
            "open_lead": { "type": "integer", "minimum": 0 },
            "related_works": { "type": "integer", "minimum": 0 },
            "related_claims": { "type": "integer", "minimum": 0 },
            "related_entities": { "type": "integer", "minimum": 0 },
            "successful_extractions": { "type": "integer", "minimum": 0 },
            "failed_extractions": { "type": "integer", "minimum": 0 },
            "zero_yield_attempts": { "type": "integer", "minimum": 0 }
          }
        },
        "source_locus_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_lead_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "related_run_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_kind",
        "subject_id",
        "selected_facet",
        "selected_prompt_bundle_id",
        "should_call_llm",
        "selection_score",
        "scoring_policy_id",
        "rationale",
        "reason_codes",
        "cycle_depth",
        "use_prior_state",
        "previous_run_ids_considered",
        "input_record_refs",
        "suggested_cli_args"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "action_kind": {
          "type": "string",
          "enum": [
            "facet_bootstrap",
            "facet_only",
            "facet_lead"
          ]
        },
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_facet": {
          "type": "string",
          "minLength": 1
        },
        "selected_prompt_bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "should_call_llm": {
          "type": "boolean"
        },
        "selected_object_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_lead_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "source_access",
            "source_claim",
            "detected_entity",
            "work",
            null
          ]
        },
        "selected_source_locus_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_source_lead_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_review_state": {
          "type": [
            "string",
            "null"
          ]
        },
        "selection_score": {
          "type": "number",
          "minimum": -100.0,
          "maximum": 100.0
        },
        "scoring_policy_id": {
          "const": "candidate-feedback.default.v1"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cycle_depth": {
          "type": "integer",
          "minimum": 1
        },
        "use_prior_state": {
          "type": "boolean"
        },
        "previous_run_ids_considered": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "input_record_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "suggested_cli_args": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "deferred_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "candidate_kind",
        "score",
        "reason"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate_kind": {
          "type": "string",
          "enum": [
            "facet",
            "lead"
          ]
        },
        "score": {
          "type": "number",
          "minimum": -100.0,
          "maximum": 100.0
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "selection_candidate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "candidate_id",
        "candidate_type",
        "selected",
        "eligibility_status",
        "rationale",
        "reason_codes",
        "metadata"
      ],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "candidate_type": { "type": "string", "minLength": 1 },
        "label": { "type": ["string", "null"] },
        "score": {
          "type": ["number", "null"],
          "minimum": -100.0,
          "maximum": 100.0
        },
        "selected": { "type": "boolean" },
        "eligibility_status": { "type": "string", "minLength": 1 },
        "rationale": { "type": ["string", "null"] },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": { "type": ["string", "null"] },
        "metadata": { "type": "object" },
        "reason": { "type": "string", "minLength": 1 },
        "policy_id": { "type": ["string", "null"] },
        "retryable": { "type": "boolean" }
      }
    },
    "selection_explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "explanation_id",
        "selection_kind",
        "subject_id",
        "workspace_id",
        "run_id",
        "cycle_event_id",
        "stage_name",
        "created_at",
        "policy",
        "budget",
        "eligibility_constraints",
        "operator_overrides",
        "selected_candidate",
        "considered_candidates",
        "excluded_candidates"
      ],
      "properties": {
        "schema_version": { "const": "selection-explanation.v1" },
        "explanation_id": { "type": "string", "minLength": 1 },
        "selection_kind": { "const": "feedback_next_action" },
        "subject_id": { "type": "string", "minLength": 1 },
        "workspace_id": { "type": ["string", "null"] },
        "run_id": { "type": ["string", "null"] },
        "cycle_event_id": { "type": ["string", "null"] },
        "stage_name": { "type": ["string", "null"] },
        "created_at": { "type": "string", "format": "date-time" },
        "policy": { "type": "object" },
        "budget": { "type": "object" },
        "eligibility_constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "operator_overrides": {
          "type": "array",
          "items": { "type": "object" }
        },
        "selected_candidate": { "$ref": "#/$defs/selection_candidate" },
        "considered_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/selection_candidate" }
        },
        "excluded_candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/selection_candidate" }
        }
      }
    }
  }
}

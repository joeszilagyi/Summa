{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/summa/crown_jewel_store_policy.schema.json",
  "title": "crown-jewel-store-policy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "backup_root",
    "notes",
    "store_families"
  ],
  "properties": {
    "schema_version": {
      "const": "crown-jewel-store-policy.v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "backup_root": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "store_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "store_key",
          "display_name",
          "path_globs",
          "durability_class",
          "storage_policy_class",
          "backup_frequency_expectation",
          "restore_expectation",
          "integrity_check_method",
          "silent_replace_forbidden",
          "missing_ok",
          "notes"
        ],
        "properties": {
          "store_key": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "path_globs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "durability_class": {
            "type": "string",
            "minLength": 1
          },
          "storage_policy_class": {
            "type": "string",
            "minLength": 1
          },
          "backup_frequency_expectation": {
            "type": "string",
            "minLength": 1
          },
          "restore_expectation": {
            "type": "string",
            "minLength": 1
          },
          "integrity_check_method": {
            "type": "string",
            "minLength": 1
          },
          "silent_replace_forbidden": {
            "type": "boolean"
          },
          "missing_ok": {
            "type": "boolean"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}

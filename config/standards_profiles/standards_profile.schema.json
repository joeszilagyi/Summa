{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summa.local/schemas/standards_profile.schema.json",
  "title": "standards-profile.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "profile_name",
    "profile_version",
    "external_standard",
    "export_format",
    "target_artifact_type",
    "conformance_level",
    "summa_source_tables",
    "field_mappings",
    "required_fields",
    "optional_fields",
    "controlled_vocabularies",
    "identifier_policy",
    "private_public_policy",
    "unsupported_fields",
    "lossy_mapping_rules",
    "validation_rules",
    "known_limitations"
  ],
  "properties": {
    "schema_version": { "const": "standards-profile.v1" },
    "profile_id": { "type": "string", "pattern": "^[a-z0-9_]+\\.v[0-9]+$" },
    "profile_name": { "type": "string", "minLength": 1 },
    "profile_version": { "type": "string", "minLength": 1 },
    "external_standard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version_or_reference", "reference_url"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version_or_reference": { "type": "string", "minLength": 1 },
        "reference_url": { "type": "string", "format": "uri" }
      }
    },
    "export_format": {
      "enum": ["dcterms_json", "premis_profile_json", "rico_profile_json", "readiness_report_json"]
    },
    "target_artifact_type": { "type": "string", "minLength": 1 },
    "conformance_level": { "enum": ["experimental", "partial", "complete", "report-only"] },
    "summa_source_tables": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "field_mappings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mapping" }
    },
    "required_fields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "optional_fields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "controlled_vocabularies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "policy"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "policy": { "type": "string", "minLength": 1 },
          "allowed_values": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          }
        }
      }
    },
    "identifier_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "stable_identifier_fields"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "base_uri_required": { "type": "boolean" },
        "stable_identifier_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "private_public_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_mode", "public_excludes"],
      "properties": {
        "default_mode": { "enum": ["public_only", "internal_only"] },
        "public_excludes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "internal_mode_requires_explicit_flag": { "type": "boolean" }
      }
    },
    "unsupported_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/unsupported" }
    },
    "lossy_mapping_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mapping_id", "reason"],
        "properties": {
          "mapping_id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "severity", "description"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["error", "warning", "info"] },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "known_limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapping_id",
        "summa_source",
        "external_target",
        "status",
        "cardinality",
        "lossy",
        "privacy",
        "validation"
      ],
      "properties": {
        "mapping_id": { "type": "string", "minLength": 1 },
        "summa_source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "field"],
          "properties": {
            "table": { "type": "string", "minLength": 1 },
            "field": { "type": "string", "minLength": 1 },
            "join_note": { "type": "string" }
          }
        },
        "external_target": { "type": "string", "minLength": 1 },
        "status": { "enum": ["required", "optional", "unsupported"] },
        "cardinality": { "type": "string", "pattern": "^[0-9n]+\\.\\.[0-9n]+$" },
        "lossy": { "type": "boolean" },
        "privacy": { "enum": ["public", "internal", "restricted"] },
        "controlled_vocabulary": { "type": "string" },
        "validation": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "unsupported": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "reason"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}

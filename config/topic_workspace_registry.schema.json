{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/subject-index/topic_workspace_registry.schema.json",
  "title": "Topic Workspace Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspaces"
  ],
  "properties": {
    "schema_version": {
      "const": "topic-workspace-registry.v1"
    },
    "default_workspace_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "notes": {
      "$ref": "#/$defs/string_array"
    },
    "workspaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workspace"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "topic_label",
        "workspace_root",
        "domain_pack",
        "lifecycle_state",
        "schedule_posture",
        "workspace_policy_class"
      ],
      "properties": {
        "workspace_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "topic_label": {
          "type": "string",
          "minLength": 1
        },
        "workspace_root": {
          "type": "string",
          "minLength": 1
        },
        "domain_pack": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "default_subject_manifest": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_state": {
          "type": "string",
          "enum": [
            "bootstrap",
            "active",
            "paused",
            "archived"
          ]
        },
        "schedule_posture": {
          "type": "string",
          "enum": [
            "manual",
            "scheduled",
            "paused"
          ]
        },
        "workspace_policy_class": {
          "type": "string",
          "enum": [
            "private_local",
            "mixed_private_public",
            "public_safe_release"
          ]
        },
        "scheduler_policy": {
          "$ref": "#/$defs/scheduler_policy"
        },
        "notes": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "scheduler_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_budget": {
          "$ref": "#/$defs/run_budget"
        },
        "retry_policy": {
          "$ref": "#/$defs/retry_policy"
        },
        "failure_state": {
          "$ref": "#/$defs/failure_state"
        },
        "saturation_state": {
          "$ref": "#/$defs/saturation_state"
        },
        "extensions": {
          "$ref": "#/$defs/extension_object"
        }
      }
    },
    "run_budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "max_runtime_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "anyOf": [
        {
          "required": ["max_attempts"]
        },
        {
          "required": ["max_runtime_seconds"]
        }
      ]
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_retryable_failures": {
          "type": "integer",
          "minimum": 1
        },
        "backoff_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "anyOf": [
        {
          "required": ["max_retryable_failures"]
        },
        {
          "required": ["backoff_seconds"]
        }
      ]
    },
    "failure_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "attempt_count"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "healthy",
            "retryable",
            "blocked"
          ]
        },
        "attempt_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_failure_at": {
          "type": "string",
          "minLength": 1
        },
        "next_retry_at": {
          "type": "string",
          "minLength": 1
        },
        "last_failure_reason": {
          "type": "string",
          "minLength": 1
        },
        "blocked_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "saturation_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "reason_codes",
        "scheduler_action"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "active",
            "active_bootstrap",
            "watch",
            "cooldown",
            "saturated",
            "manually_paused",
            "reactivated",
            "not_evaluated"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scheduler_action": {
          "type": "string",
          "enum": [
            "run",
            "deprioritize",
            "cooldown",
            "halt"
          ]
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "evaluated_at": {
          "type": "string",
          "minLength": 1
        },
        "next_eligible_cycle": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "recent_yield_summary": {
          "type": "object"
        },
        "extensions": {
          "$ref": "#/$defs/extension_object"
        }
      }
    },
    "extension_object": {
      "type": "object",
      "additionalProperties": true
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summa.local/schemas/migration_ledger.schema.json",
  "title": "migration-ledger.v1 event",
  "description": "Append-only JSONL event contract for schema, artifact-contract, and rollback migration history.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "workspace_id",
    "migration_id",
    "migration_type",
    "subject_ref",
    "tool_surface",
    "tool_version",
    "input_version",
    "output_version",
    "input_artifact_refs",
    "output_artifact_refs",
    "occurred_at",
    "note"
  ],
  "properties": {
    "schema_version": {
      "const": "migration-ledger.v1"
    },
    "event_id": {
      "type": "string",
      "pattern": "^mle:[a-z0-9][a-z0-9._:-]*$"
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "migration_id": {
      "type": "string",
      "pattern": "^mig:[a-z0-9][a-z0-9._:-]*$"
    },
    "migration_type": {
      "type": "string",
      "enum": [
        "schema_migration",
        "artifact_contract_migration",
        "rollback_reference"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "tool_surface": {
      "type": "string",
      "minLength": 1
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "input_version": {
      "type": "string",
      "minLength": 1
    },
    "output_version": {
      "type": "string",
      "minLength": 1
    },
    "input_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_ref"
      }
    },
    "output_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_ref"
      }
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "backup_ref": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "rollback_of_event_id": {
      "type": "string",
      "pattern": "^mle:[a-z0-9][a-z0-9._:-]*$"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "note": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "path"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

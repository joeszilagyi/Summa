{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/summa/gather_candidate_batch.schema.json",
  "title": "gather-candidate-batch.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "mode",
    "phase",
    "engine",
    "subject",
    "domain_pack",
    "facet",
    "prompt_bundle",
    "prompt",
    "source_text_wrapping",
    "provenance",
    "candidates",
    "raw_engine_output",
    "engine_output_ref",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "gather-candidate-batch.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "dry_run",
        "live"
      ]
    },
    "iteration_mode": {
      "type": "string",
      "enum": [
        "one_shot",
        "prior_state"
      ]
    },
    "cycle_depth": {
      "type": "integer",
      "minimum": 1
    },
    "previous_run_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prior_state": {
      "$ref": "#/$defs/prior_state"
    },
    "feedback_plan": {
      "$ref": "#/$defs/feedback_plan"
    },
    "phase": {
      "type": "string",
      "enum": [
        "01a",
        "01r"
      ]
    },
    "engine": {
      "$ref": "#/$defs/engine"
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "domain_pack": {
      "$ref": "#/$defs/domain_pack"
    },
    "facet": {
      "$ref": "#/$defs/facet"
    },
    "prompt_bundle": {
      "$ref": "#/$defs/prompt_bundle"
    },
    "prompt": {
      "$ref": "#/$defs/prompt"
    },
    "source_text_wrapping": {
      "$ref": "#/$defs/source_text_wrapping"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "raw_engine_output": {
      "type": [
        "string",
        "null"
      ]
    },
    "engine_output_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "validation": {
      "$ref": "#/$defs/validation"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_engine",
        "resolved_engine",
        "invoked",
        "engine_present",
        "runner_path",
        "bridge_path"
      ],
      "properties": {
        "requested_engine": {
          "type": "string",
          "enum": [
            "codex",
            "claude"
          ]
        },
        "resolved_engine": {
          "type": [
            "string",
            "null"
          ]
        },
        "invoked": {
          "type": "boolean"
        },
        "engine_present": {
          "type": "boolean"
        },
        "runner_path": {
          "type": "string",
          "minLength": 1
        },
        "bridge_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "display_name",
        "domain_pack",
        "scope_statement",
        "enabled_facets",
        "query_families",
        "manifest_path",
        "workspace_root",
        "resolution_source"
      ],
      "properties": {
        "subject_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "domain_pack": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "scope_statement": {
          "type": "string",
          "minLength": 1
        },
        "enabled_facets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "query_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "workspace_root": {
          "type": "string",
          "minLength": 1
        },
        "resolution_source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "domain_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "schema_version",
        "display_name",
        "status",
        "path",
        "enabled_facets",
        "selected_facet",
        "prompt_bundle_key",
        "prompt_bundle_id"
      ],
      "properties": {
        "pack_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "schema_version": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "enabled_facets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selected_facet": {
          "type": "string",
          "minLength": 1
        },
        "prompt_bundle_key": {
          "type": "string",
          "minLength": 1
        },
        "prompt_bundle_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "facet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "phase",
        "candidate_type_hint"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": [
            "01a",
            "01r"
          ]
        },
        "candidate_type_hint": {
          "type": "string",
          "enum": [
            "source_lead",
            "timeline_item",
            "person",
            "place",
            "work",
            "open_question",
            "unknown",
            "raw_candidate_text"
          ]
        }
      }
    },
    "prompt_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_key",
        "bundle_id",
        "template_ids",
        "template_files",
        "selected_template_id",
        "selected_template_file",
        "wrapper_template_id"
      ],
      "properties": {
        "bundle_key": {
          "type": "string",
          "minLength": 1
        },
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "template_ids": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "template_files": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selected_template_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_template_file": {
          "type": "string",
          "minLength": 1
        },
        "wrapper_template_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "prior_state_count_bucket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "selected",
        "rendered"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "selected": {
          "type": "integer",
          "minimum": 0
        },
        "rendered": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "prior_state_previous_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "event_timestamp",
        "cycle_depth"
      ],
      "properties": {
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "event_timestamp": {
          "type": "string",
          "minLength": 1
        },
        "cycle_depth": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    },
    "prior_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "source",
        "limits",
        "record_counts",
        "previous_runs",
        "records",
        "truncated",
        "context_text",
        "context_hash"
      ],
      "properties": {
        "policy": {
          "const": "accepted-and-open-leads"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "subject_id",
            "schema_version",
            "subject_scope"
          ],
          "properties": {
            "kind": {
              "const": "canonical_store"
            },
            "subject_id": {
              "type": "string",
              "minLength": 1
            },
            "schema_version": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "subject_scope": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "per_family_limit",
            "max_chars",
            "max_prior_cycles",
            "high_confidence_threshold"
          ],
          "properties": {
            "per_family_limit": {
              "type": "integer",
              "minimum": 0
            },
            "max_chars": {
              "type": "integer",
              "minimum": 1
            },
            "max_prior_cycles": {
              "type": "integer",
              "minimum": 0
            },
            "high_confidence_threshold": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "record_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "works",
            "entities",
            "source_claims",
            "source_access",
            "relationships",
            "extraction_summaries",
            "previous_runs"
          ],
          "properties": {
            "works": {
              "$ref": "#/$defs/prior_state_count_bucket"
            },
            "entities": {
              "$ref": "#/$defs/prior_state_count_bucket"
            },
            "source_claims": {
              "$ref": "#/$defs/prior_state_count_bucket"
            },
            "source_access": {
              "$ref": "#/$defs/prior_state_count_bucket"
            },
            "relationships": {
              "$ref": "#/$defs/prior_state_count_bucket"
            },
            "extraction_summaries": {
              "$ref": "#/$defs/prior_state_count_bucket"
            },
            "previous_runs": {
              "$ref": "#/$defs/prior_state_count_bucket"
            }
          }
        },
        "previous_runs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prior_state_previous_run"
          }
        },
        "previous_run_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "records": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "works",
            "entities",
            "source_claims",
            "source_access",
            "relationships",
            "extraction_summaries"
          ],
          "properties": {
            "works": {
              "type": "array"
            },
            "entities": {
              "type": "array"
            },
            "source_claims": {
              "type": "array"
            },
            "source_access": {
              "type": "array"
            },
            "relationships": {
              "type": "array"
            },
            "extraction_summaries": {
              "type": "array"
            }
          }
        },
        "truncated": {
          "type": "boolean"
        },
        "context_text": {
          "type": "string",
          "minLength": 1
        },
        "context_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "feedback_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "plan_path",
        "plan_hash",
        "next_action_id",
        "plan_selected_facet",
        "applied_facet",
        "selected_prompt_bundle_id",
        "applied_prompt_bundle_id",
        "selection_score",
        "scoring_policy_id",
        "rationale",
        "use_prior_state",
        "cycle_depth",
        "previous_run_ids_considered"
      ],
      "properties": {
        "schema_version": {
          "const": "candidate-feedback-plan.v1"
        },
        "plan_path": {
          "type": "string",
          "minLength": 1
        },
        "plan_hash": {
          "$ref": "#/$defs/sha256"
        },
        "next_action_id": {
          "type": "string",
          "minLength": 1
        },
        "plan_selected_facet": {
          "type": "string",
          "minLength": 1
        },
        "applied_facet": {
          "type": "string",
          "minLength": 1
        },
        "selected_prompt_bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "applied_prompt_bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_object_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_lead_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "selection_score": {
          "type": "number"
        },
        "scoring_policy_id": {
          "const": "candidate-feedback.default.v1"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "use_prior_state": {
          "type": "boolean"
        },
        "cycle_depth": {
          "type": "integer",
          "minimum": 1
        },
        "previous_run_ids_considered": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_action": {
          "type": "object"
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rendered_prompt_path",
        "rendered_prompt_hash"
      ],
      "properties": {
        "rendered_prompt_path": {
          "type": "string",
          "minLength": 1
        },
        "rendered_prompt_hash": {
          "$ref": "#/$defs/sha256"
        },
        "rendered_prompt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "wrapped_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "source_ref",
        "provenance",
        "hazard_flags",
        "start_offset",
        "end_offset",
        "byte_count",
        "sha256"
      ],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "type": "string",
          "minLength": 1
        },
        "hazard_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "start_offset": {
          "type": "integer",
          "minimum": 0
        },
        "end_offset": {
          "type": "integer",
          "minimum": 0
        },
        "byte_count": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "source_text_wrapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wrapper_template_id",
        "begin_delimiter",
        "end_delimiter",
        "source_block_count",
        "blocks"
      ],
      "properties": {
        "wrapper_template_id": {
          "type": "string",
          "minLength": 1
        },
        "begin_delimiter": {
          "type": "string",
          "minLength": 1
        },
        "end_delimiter": {
          "type": "string",
          "minLength": 1
        },
        "source_block_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/wrapped_block"
          }
        }
      }
    },
    "stamp_footer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_meta_version",
        "generated_by",
        "model",
        "place",
        "facet",
        "phase",
        "run_ts"
      ],
      "properties": {
        "run_meta_version": {
          "type": "string",
          "minLength": 1
        },
        "generated_by": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "place": {
          "type": "string",
          "minLength": 1
        },
        "facet": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "run_ts": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "driver_name",
        "driver_version",
        "command",
        "llm_runner_path",
        "llm_runner_bridge_path",
        "engine_name",
        "engine_invoked",
        "engine_present",
        "timestamp",
        "network_access_attempted",
        "stamped_output_path",
        "stamped_output_footer"
      ],
      "properties": {
        "driver_name": {
          "type": "string",
          "minLength": 1
        },
        "driver_version": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "llm_runner_path": {
          "type": "string",
          "minLength": 1
        },
        "llm_runner_bridge_path": {
          "type": "string",
          "minLength": 1
        },
        "engine_name": {
          "type": "string",
          "enum": [
            "codex",
            "claude"
          ]
        },
        "engine_invoked": {
          "type": "boolean"
        },
        "engine_present": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        },
        "network_access_attempted": {
          "const": false
        },
        "prior_state_enabled": {
          "type": "boolean"
        },
        "prior_state_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "feedback_plan_enabled": {
          "type": "boolean"
        },
        "feedback_plan_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "scoring_policy_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "cycle_depth": {
          "type": "integer",
          "minimum": 1
        },
        "stamped_output_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "stamped_output_footer": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "candidate_type",
        "review_status",
        "persistence_status",
        "origin",
        "text"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^cand:[a-z0-9][a-z0-9._:-]*$"
        },
        "candidate_type": {
          "type": "string",
          "enum": [
            "source_lead",
            "timeline_item",
            "person",
            "place",
            "work",
            "open_question",
            "unknown",
            "raw_candidate_text"
          ]
        },
        "review_status": {
          "const": "unverified"
        },
        "persistence_status": {
          "const": "workspace_run_only"
        },
        "origin": {
          "const": "llm_proposed"
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator",
        "status",
        "errors"
      ],
      "properties": {
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "pass"
        },
        "errors": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}

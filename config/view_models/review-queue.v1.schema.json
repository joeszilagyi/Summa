{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "view-model://review-queue.v1",
  "title": "review-queue.v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "database_path",
    "filters",
    "writer",
    "counts",
    "truncated",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "review-queue.v1"
    },
    "database_path": {
      "type": "string"
    },
    "filters": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "object_type": {"type": ["string", "null"]},
        "state": {"type": ["string", "null"]},
        "min_confidence": {"type": ["number", "null"]},
        "max_confidence": {"type": ["number", "null"]},
        "source_type": {"type": ["string", "null"]},
        "workspace_id": {"type": ["string", "null"]},
        "authority_level": {"type": ["string", "null"]},
        "public_blocker": {"type": ["string", "null"]},
        "limit": {"type": ["integer", "null"]}
      }
    },
    "writer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["surface_path", "supported_actions"],
      "properties": {
        "surface_path": {"type": "string"},
        "supported_actions": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "counts": {
      "type": "object"
    },
    "truncated": {
      "type": "boolean"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "object_ref": {"type": ["string", "null"]},
          "object_type": {"type": ["string", "null"]},
          "object_namespace": {"type": ["string", "null"]},
          "object_pk": {"type": ["integer", "null"]},
          "review_state": {"type": ["string", "null"]},
          "confidence_score": {"type": ["number", "null"]},
          "source_type": {"type": ["string", "null"]},
          "workspace_id": {"type": ["string", "null"]},
          "authority_level": {"type": ["string", "null"]},
          "public_blocker": {"type": ["string", "null"]},
          "label": {"type": ["string", "null"]},
          "available_actions": {"type": "object"}
        }
      }
    }
  }
}

{
  "schema_version": "source-adapter.v1",
  "adapter_id": "runtime_local_directory",
  "display_name": "Runtime local directory",
  "workspace_id": "alpha_subject",
  "description": "Runtime fixture for local directory enumeration.",
  "input_family": "local_directory",
  "locator": {
    "local_path": "corpus",
    "include_globs": [
      "**/*.pdf",
      "**/*.json"
    ],
    "exclude_globs": [
      "excluded/**",
      "**/*.tmp"
    ]
  },
  "content_profile": {
    "content_kinds": [
      "pdf",
      "json"
    ],
    "hazard_flags": [
      "prompt_injection_text"
    ]
  },
  "provenance": {
    "discovery_provenance": "runtime fixture corpus",
    "acquisition_method": "manual_drop",
    "source_description": "Mixed local directory for runtime planning tests."
  },
  "rights_and_storage": {
    "payload_storage_policy_class": "private_only",
    "metadata_storage_policy_class": "tracked_derived",
    "rights_posture": "private_local_only",
    "contains_personal_data": false
  },
  "automation_posture": "operator_review_required",
  "normalized_handoff": {
    "record_family": "capture",
    "batch_unit": "per_file",
    "preserve_fields": [
      "original_locator",
      "discovery_provenance",
      "rights_posture",
      "byte_retention_status",
      "discard_metadata",
      "refetchability_status",
      "transform_lineage",
      "source_metadata"
    ],
    "source_specific_fields": [
      "relative_path",
      "source_filename"
    ]
  },
  "transform_lineage": [
    {
      "step_id": "enumerate",
      "step_kind": "enumerate_members",
      "description": "Enumerate matching files.",
      "deterministic": true,
      "review_required": false
    },
    {
      "step_id": "handoff",
      "step_kind": "emit_handoff",
      "description": "Emit local capture handoff records.",
      "deterministic": true,
      "review_required": true
    }
  ]
}
